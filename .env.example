# --- REQUIRED -------------------------------------------------

# Telegram bot token from @BotFather
BOT_TOKEN=

# Anthropic API key — https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# --- WEBHOOK --------------------------------------------------
# Set automatically on Railway via RAILWAY_PUBLIC_DOMAIN.
# Override only if deploying elsewhere:
# WEBHOOK_URL=https://yourdomain.com

# --- OPTIONAL: WordPress publishing ---------------------------
WP_URL=https://yourblog.example.com
WP_USER=admin
WP_APP_PASSWORD=
# draft | publish
WP_DEFAULT_STATUS=draft

# --- OPTIONAL: Telegram channel publishing --------------------
# Numeric ID like -1001234567890, or @channelusername.
# The bot must be an admin of the channel with post permissions.
TG_CHANNEL_ID=

# --- OPTIONAL: model override ---------------------------------
# CLAUDE_MODEL=claude-sonnet-4-6
