# ── Telegram ──────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_name

# ── Claude (Anthropic) ────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Генерация изображений ─────────────────
# Ideogram (предпочтительно)
IDEOGRAM_API_KEY=your_ideogram_key

# DALL-E (запасной вариант)
OPENAI_API_KEY=sk-...

# ── Проверка плагиата ─────────────────────
TEXTRU_API_KEY=your_textru_key

# ── WordPress сайты ───────────────────────
# Формат: URL|username|application_password
# App Password создаётся в WP: Users → Profile → Application Passwords
WP_SITE_1=https://yoursite.com|admin|xxxx xxxx xxxx xxxx xxxx xxxx
WP_SITE_2=https://yoursite2.com|admin|xxxx xxxx xxxx xxxx xxxx xxxx
