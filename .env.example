# --- REQUIRED -------------------------------------------------

# Telegram bot token from @BotFather
BOT_TOKEN=

# Anthropic API key — https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=

# --- OPTIONAL: WordPress publishing -----------------------------
# Create an Application Password in WP Admin:
#   Users → your profile → Application Passwords → Add New
WP_URL=https://yourblog.example.com
WP_USER=admin
WP_APP_PASSWORD=
# draft | publish — default for newly published posts
WP_DEFAULT_STATUS=draft

# --- OPTIONAL: Telegram channel publishing ----------------------
# Numeric ID like -1001234567890, or @channelusername.
# The bot must be an admin of the channel (with post-message rights).
TG_CHANNEL_ID=

# --- OPTIONAL: model override ----------------------------------
# Defaults to claude-sonnet-4-6 if unset.
# CLAUDE_MODEL=claude-sonnet-4-6
